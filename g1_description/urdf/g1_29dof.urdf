  <link name="d435_link_optical"></link>
    <joint name="d435_optical_joint" type="fixed">
      <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
      <parent link="d435_link"/>
      <child link="d435_link_optical"/>
    </joint>

  <gazebo reference="d435_link">
    <sensor name="realsense_d435" type="rgbd_camera">
      <topic>camera</topic> <update_rate>30</update_rate>
      <always_on>true</always_on>
      <visualize>true</visualize>
      <camera name="camera">
        <horizontal_fov>1.50098</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format> </image>
        <clip>
          <near>0.1</near>
          <far>10.0</far>
        </clip>
      </camera>
      <ignition_frame_id>d435_link</ignition_frame_id> 
    </sensor>
  </gazebo>

  <gazebo reference="mid360_link">
    <sensor name="mid360_lidar" type="gpu_lidar">
      <topic>lidar/points</topic>
      <update_rate>10</update_rate>
      <always_on>true</always_on>
      <visualize>true</visualize> <lidar>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
          <vertical>
            <samples>32</samples>
            <resolution>1</resolution>
            <min_angle>-0.12217</min_angle> <max_angle>0.90757</max_angle>  </vertical>
        </scan>
        <range>
          <min>0.1</min>
          <max>40.0</max>
          <resolution>0.01</resolution>
        </range>
      </lidar>
      <ignition_frame_id>mid360_link</ignition_frame_id>
    </sensor>
  </gazebo>
  
  <gazebo>
    <plugin filename="ign_ros2_control-system" name="ign_ros2_control::IgnitionROS2ControlPlugin">
      <parameters>$(find g1_description)/config/ros2_controllers.yaml</parameters>
    </plugin>
  </gazebo>

</robot>